{
  "name": "kirsten-rossiter-tokens",
  "version": "0.1.0",
  "description": "Design token pipeline for Kirsten Rossiter using Style Dictionary",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./light.css": "./dist/light/variables.css",
    "./dark.css": "./dist/dark/variables.css",
    "./light": "./dist/light/tokens.js",
    "./dark": "./dist/dark/tokens.js",
    "./light.json": "./dist/light/tokens.flat.json",
    "./dark.json": "./dist/dark/tokens.flat.json",
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "*.css"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "node sd.config.mjs && node scripts/snapshot-tokens.mjs",
    "generate-docs": "node scripts/generate-docs.mjs",
    "scaffold-client": "node scripts/scaffold-client.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic",
    "verify": "node scripts/verify-build.mjs",
    "prepublishOnly": "npm run build && npm run verify",
    "test": "npm run build && npm run verify"
  },
  "keywords": [
    "design-tokens",
    "design-system",
    "css-variables",
    "style-dictionary",
    "idem"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@vitejs/plugin-react": "^4.7.0",
    "chromatic": "^17.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "storybook": "^8.6.18",
    "style-dictionary": "^4.4.0",
    "vite": "^6.4.3"
  },
  "main": "dist/light/tokens.js"
}
